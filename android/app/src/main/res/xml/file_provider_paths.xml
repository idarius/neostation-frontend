<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Permite acceso a almacenamiento externo (tarjetas SD, USB, etc) -->
    <external-path name="external_storage" path="." />
    
    <!-- Permite acceso a almacenamiento externo raíz -->
    <root-path name="root" path="." />
    
    <!-- Permite acceso a directorios específicos si es necesario -->
    <external-files-path name="external_files" path="." />
    <external-cache-path name="external_cache" path="." />
    
    <!-- Permite acceso a cache interno para instalación de APKs -->
    <cache-path name="cache" path="." />
    <files-path name="files" path="." />
</paths>
