{
  "categories": [
    {
      "title": "## Features",
      "labels": [
        "feature",
        "enhancement",
        "feat"
      ]
    },
    {
      "title": "## Fixes",
      "labels": [
        "fix",
        "bug"
      ]
    },
    {
      "title": "## Maintenance",
      "labels": [
        "chore",
        "refactor",
        "docs",
        "style",
        "ci",
        "perf",
        "test"
      ]
    },
    {
      "title": "## Dependencies",
      "labels": [
        "dependencies"
      ]
    },
    {
      "title": "## Other",
      "labels": []
    }
  ],
  "sort": "ASC",
  "template": "${{CHANGELOG}}\n\n**Full Changelog**: ${{RELEASE_DIFF}}",
  "pr_template": "- ${{TITLE}} (#${{NUMBER}}) @${{AUTHOR}}",
  "empty_template": "- No changes",
  "max_pull_requests": 100,
  "max_back_track_time_days": 365
}