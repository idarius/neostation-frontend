<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Enable Sandbox (User requested) -->
	<key>com.apple.security.app-sandbox</key>
	<true/>

	<!-- File Access (REQUIRED if Sandbox is true) -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<key>com.apple.security.files.downloads.read-write</key>
	<true/>
	
	<!-- Temporary exception exactly as in Release (for broad access) -->
	<key>com.apple.security.temporary-exception.files.absolute-path.read-write</key>
	<array>
		<string>/Users/</string>
	</array>
	
	<!-- Allow loading third-party libraries (important for plugins) -->
	<key>com.apple.security.cs.disable-library-validation</key>
	<true/>
	
	<!-- Allow DYLD variables (standard for release builds) -->
	<key>com.apple.security.cs.allow-dyld-environment-variables</key>
	<true/>
	
	<!-- Jit/Unsigned exec memory (useful for emulators/Dart) -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.cs.allow-unsigned-executable-memory</key>
	<true/>
	
	<!-- Network Client (Usually implied but good to be explicit) -->
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
