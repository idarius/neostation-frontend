# NeoStation build-time environment variables.
# Pass these via --dart-define when building or running the app.
#
# Example:
#   flutter run \
#     --dart-define=RA_API_KEY=your_key \
#     --dart-define=SCREENSCRAPER_DEV_ID=your_id \
#     --dart-define=SCREENSCRAPER_DEV_PASSWORD=your_password
#
# Or create a launch.json entry in VS Code with these args.

# RetroAchievements API key — https://retroachievements.org/controlpanel.php
RA_API_KEY=

# ScreenScraper developer credentials — https://www.screenscraper.fr/forumsujets.php?frub=12
SCREENSCRAPER_DEV_ID=
SCREENSCRAPER_DEV_PASSWORD=
